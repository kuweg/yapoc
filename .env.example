# YAPOC environment template — copy to `.env` and fill in.
#
# Only fill the keys for providers you actually plan to use. Everything has
# a sensible default in `app/config/settings.py`, so an empty .env still
# boots — you just can't reach any cloud LLM without at least one API key.

# ── LLM API keys ─────────────────────────────────────────────────────────
# Anthropic (primary)        https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI                     https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini              https://aistudio.google.com/apikey
# (GOOGLE_API_KEY or GEMINI_API_KEY both work; the code accepts either.)
GOOGLE_API_KEY=

# DeepSeek                   https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenRouter (multi-provider aggregator)   https://openrouter.ai/keys
OPENROUTER_API_KEY=

# LM Studio (local) — only needed if you enabled API auth in LM Studio.
LMSTUDIO_API_KEY=

# ── Local / self-hosted LLM endpoints ────────────────────────────────────
# Override only if your local server runs on a non-default port/host.
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234

# ── Default model ────────────────────────────────────────────────────────
# Used when an agent's CONFIG.yaml / agent-settings.json don't specify one.
DEFAULT_ADAPTER=anthropic
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_TEMPERATURE=0.7

# How many fallback models per agent are honored from
# app/config/agent-settings.json. Default 1; bump to 3 for full cross-provider
# failover (anthropic → openai → google).
DEFAULT_N_FALLBACKS_MODELS=1

# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Comma-separated origins for the CORS middleware.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Message bus ──────────────────────────────────────────────────────────
# Redis is a hard dependency for the inter-agent message bus. The
# notification queue file fallback only catches edge cases — not a soft
# mode. Spin up a local redis with: `redis-server` (no auth needed for dev).
REDIS_URL=redis://localhost:6379

# ── Cost governance ──────────────────────────────────────────────────────
# Hard pauses to keep autonomous runs from going off the rails.
BUDGET_PER_TASK_USD=2.0
BUDGET_PER_AGENT_USD=0.0          # 0 = no per-agent cap
DAILY_AUTONOMOUS_BUDGET_USD=10.0  # cap for cron/goal/doctor-source tasks

# ── Voice / TTS ──────────────────────────────────────────────────────────
VOICE_ENABLED=true
# offline | openai | google — OpenAI requires OPENAI_API_KEY.
TTS_ENGINE=openai
TTS_VOICE=
TTS_SPEED=1.0
# offline | openai | google
STT_ENGINE=offline

# ── Webhook ──────────────────────────────────────────────────────────────
# Bearer token guarding `/webhook/task`. Empty value disables the endpoint
# entirely — set this only if you want to accept external task POSTs.
WEBHOOK_SECRET=

# ── Telegram bot (optional) ──────────────────────────────────────────────
# Token from @BotFather; empty = bot disabled (no lifespan startup).
TELEGRAM_BOT_TOKEN=
# Shared secret for the bot's /auth command. Empty = no auth required
# (do NOT do this if the bot is reachable from the public internet).
TELEGRAM_AUTH_PIN=
# JSON list of Telegram chat IDs that bypass /auth, e.g. [148007138]
TELEGRAM_WHITELIST=[]

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Empty = stderr only. Set a path to enable rotating-file output.
LOG_FILE=
LOG_JSON=false

# ── Anthropic thinking (Claude 4+) ──────────────────────────────────────
# Enable extended thinking for agents that route through Anthropic.
ENABLE_THINKING=false
THINKING_BUDGET_TOKENS=24000
