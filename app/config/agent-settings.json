{
  "version": 2,
  "description": "Central agent -> model binding with cross-provider fallbacks. No API keys are stored on disk — keys are always resolved from the environment via app.config.settings at runtime. Per-agent optional fields: temperature, max_tokens, fallbacks, task_timeout (seconds, default 300), idle_timeout (seconds, default 900).",
  "default_n_fallbacks_models": 3,
  "stale_task_threshold_seconds": 600,
  "agents": {
    "master": {
      "adapter": "deepseek",
      "model": "deepseek-chat",
      "temperature": 0.3,
      "max_tokens": 8096,
      "fallbacks": [
        {
          "adapter": "anthropic",
          "model": "claude-sonnet-4-6"
        },
        {
          "adapter": "openai",
          "model": "gpt-5.4-mini"
        },
        {
          "adapter": "google",
          "model": "gemini-2.5-flash"
        }
      ]
    },
    "planning": {
      "adapter": "deepseek",
      "model": "deepseek-v4-pro",
      "temperature": 0.3,
      "max_tokens": 8096,
      "fallbacks": [
        {
          "adapter": "deepseek",
          "model": "deepseek-chat"
        },
        {
          "adapter": "anthropic",
          "model": "claude-sonnet-4-6"
        },
        {
          "adapter": "google",
          "model": "gemini-2.5-flash"
        }
      ]
    },
    "builder": {
      "adapter": "deepseek",
      "model": "deepseek-chat",
      "temperature": 0.2,
      "max_tokens": 8096,
      "fallbacks": [
        {
          "adapter": "codex",
          "model": "gpt-5.1-codex"
        },
        {
          "adapter": "openai",
          "model": "gpt-5.2"
        },
        {
          "adapter": "google",
          "model": "gemini-2.5-pro"
        }
      ]
    },
    "keeper": {
      "adapter": "openai",
      "model": "gpt-4.1-nano",
      "temperature": 0.2,
      "max_tokens": 4096,
      "fallbacks": [
        {
          "adapter": "anthropic",
          "model": "claude-sonnet-4-6"
        },
        {
          "adapter": "openai",
          "model": "gpt-5.4-mini"
        },
        {
          "adapter": "google",
          "model": "gemini-2.5-flash-lite"
        }
      ]
    },
    "cron": {
      "adapter": "openai",
      "model": "gpt-4.1-nano",
      "temperature": 0.2,
      "max_tokens": 4096,
      "fallbacks": [
        {
          "adapter": "anthropic",
          "model": "claude-sonnet-4-6"
        },
        {
          "adapter": "openai",
          "model": "gpt-5.4-mini"
        },
        {
          "adapter": "google",
          "model": "gemini-2.5-flash-lite"
        }
      ]
    },
    "doctor": {
      "adapter": "openai",
      "model": "gpt-5.4-mini",
      "temperature": 0.2,
      "max_tokens": 4096,
      "fallbacks": [
        {
          "adapter": "google",
          "model": "gemini-2.5-flash"
        },
        {
          "adapter": "anthropic",
          "model": "claude-sonnet-4-6"
        }
      ]
    },
    "model_manager": {
      "adapter": "openai",
      "model": "gpt-5.4-nano",
      "temperature": 0.2,
      "max_tokens": 4096,
      "fallbacks": [
        {
          "adapter": "openai",
          "model": "gpt-5.4-mini"
        },
        {
          "adapter": "google",
          "model": "gemini-2.5-flash-lite"
        },
        {
          "adapter": "anthropic",
          "model": "claude-sonnet-4-6"
        }
      ]
    }
  }
}